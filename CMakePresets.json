{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 26,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_FLAGS_DEBUG": "-g -Werror"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_FLAGS_RELEASE": "-O3 -Wall -Werror -Wno-stringop-overflow -DNDEBUG -flto -ffunction-sections -fdata-sections -fvisibility=hidden -fvisibility-inlines-hidden",
        "CMAKE_EXE_LINKER_FLAGS_RELEASE": "-flto -Wno-stringop-overflow",
        "CMAKE_INTERPROCEDURAL_OPTIMIZATION_RELEASE": "ON"
      }
    },
    {
      "name": "debug-test",
      "displayName": "Debug (Tests)",
      "inherits": "debug",
      "cacheVariables": {
        "BUILD_TESTING": "ON"
      }
    },
    {
      "name": "release-test",
      "displayName": "Release (Tests)",
      "inherits": "release",
      "cacheVariables": {
        "BUILD_TESTING": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "displayName": "Debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "displayName": "Release",
      "configurePreset": "release"
    },
    {
      "name": "debug-test",
      "displayName": "Debug (Tests)",
      "configurePreset": "debug-test"
    },
    {
      "name": "release-test",
      "displayName": "Release (Tests)",
      "configurePreset": "release-test"
    }
  ],
  "testPresets": [
    {
      "name": "debug-test",
      "displayName": "Debug (Tests)",
      "configurePreset": "debug-test",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release-test",
      "displayName": "Release (Tests)",
      "configurePreset": "release-test",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
